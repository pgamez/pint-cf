{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "options": {
        "env": {
            "PATH": "${workspaceFolder}/.venv/bin:${env:PATH}"
        }
    },
    "tasks": [
        {
            "label": "Build docs",
            "type": "shell",
            "command": "make -C docs clean && make -C docs html",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Generate Pint registry",
            "type": "shell",
            "command": "python ${workspaceFolder}/tools/parse_xml.py ${workspaceFolder}/tools/xml/udunits2.xml",
            "problemMatcher": []
        }
    ]
}
